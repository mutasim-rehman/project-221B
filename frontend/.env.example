# 221B Baker Street — frontend API configuration
# Copy to .env and adjust for your environment.
# .env is gitignored and must never be committed.

# Option A: Hugging Face Gradio Space (recommended for deployment)
VITE_GRADIO_SPACE=mutasim-rehman/appledoor
# Optional: HF token for private Spaces
# VITE_HF_TOKEN=hf_xxx

# Option B: Custom backend API (base URL, no trailing slash)
# VITE_API_BASE=http://localhost:8000
