#############################################
# 221B Baker Street — local RAG settings   #
#############################################

# Ollama model to use for answering questions and character chat.
# Defaults to `llama3.2` if unset.
# No API key is required; Ollama runs locally.
# OLLAMA_MODEL=llama3.2

# Maximum time (in seconds) to wait for a single Ollama generation
# before failing with a timeout error.
# OLLAMA_TIMEOUT_SECONDS=60

# Maximum number of characters accepted for a single user question.
# Longer inputs are rejected to avoid runaway prompts or DoS-style input.
# MAX_QUERY_CHARS=2000

# When you add an HTTP API (FastAPI), consider adding:
# - APP_PORT                — listening port for the API server
# - APP_LOG_LEVEL           — logging level (e.g. info, debug)
# - APP_API_KEY             — shared secret for simple auth in front of the API
# - RATE_LIMIT_PER_MINUTE   — max requests per client per minute
# These are not used by the CLI today but should be configured in production.
